from __future__ import annotations

import argparse
import gzip
import re
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Any, Iterable

import pandas as pd

from fvn_dfm.normalization.sec_filing_event import (
    accession_no_dashes,
    normalize_cik_10,
    normalize_cik_no_leading_zeros,
)
from fvn_dfm.utils.io import ensure_dir
from fvn_dfm.utils.logging import get_logger
from fvn_dfm.utils.paths import root
from fvn_dfm.utils.trading_calendar import (
    DEFAULT_MARKET_TIMEZONE,
    first_allowed_execution_date,
    load_holidays,
    localize_naive_edgar_datetime,
)


ACCEPTANCE_DATETIME_RE = re.compile(r"<ACCEPTANCE-DATETIME>\s*(?P<value>\d{14})", re.IGNORECASE)
SEC_HEADER_END_RE = re.compile(r"</SEC-HEADER>", re.IGNORECASE)
DOCUMENT_START_RE = re.compile(r"<DOCUMENT>", re.IGNORECASE)

HEADER_FIELD_PATTERNS = {
    "accession_number_header": re.compile(r"ACCESSION NUMBER:\s*(?P<value>[0-9\-]+)", re.IGNORECASE),
    "submission_type_header": re.compile(r"CONFORMED SUBMISSION TYPE:\s*(?P<value>[A-Z0-9/\-]+)", re.IGNORECASE),
    "filed_as_of_date_header": re.compile(r"FILED AS OF DATE:\s*(?P<value>\d{8})", re.IGNORECASE),
    "period_of_report_header": re.compile(r"CONFORMED PERIOD OF REPORT:\s*(?P<value>\d{8})", re.IGNORECASE),
    "company_conformed_name": re.compile(r"COMPANY CONFORMED NAME:\s*(?P<value>.+)", re.IGNORECASE),
    "central_index_key": re.compile(r"CENTRAL INDEX KEY:\s*(?P<value>\d+)", re.IGNORECASE),
    "standard_industrial_classification": re.compile(
        r"STANDARD INDUSTRIAL CLASSIFICATION:\s*(?P<value>.+)", re.IGNORECASE
    ),
    "irs_number": re.compile(r"IRS NUMBER:\s*(?P<value>\d+)", re.IGNORECASE),
    "state_of_incorporation": re.compile(r"STATE OF INCORPORATION:\s*(?P<value>[A-Z]+)", re.IGNORECASE),
    "fiscal_year_end": re.compile(r"FISCAL YEAR END:\s*(?P<value>\d{4})", re.IGNORECASE),
}


@dataclass(frozen=True)
class FilingAvailabilityConfig:
    complete_submissions_dir: Path
    filing_event_path: Path | None
    output_table_path: Path
    output_csv_path: Path
    holidays_path: Path | None = None
    timezone_name: str = DEFAULT_MARKET_TIMEZONE
    market_close_hour: int = 16
    market_close_minute: int = 0


FILING_AVAILABILITY_COLUMNS = [
    "cik",
    "cik10",
    "accession_number",
    "accession_no_dashes",
    "form_type_from_header",
    "form_type_from_event",
    "filing_date_from_header",
    "filing_date_from_event",
    "report_date_from_header",
    "report_date_from_event",
    "accepted_at_edgar_raw",
    "accepted_at_edgar",
    "accepted_at_edgar_timezone",
    "accepted_at_edgar_date",
    "accepted_at_edgar_time",
    "first_allowed_execution_date",
    "execution_policy",
    "header_source_file",
    "source_file_size_bytes",
    "company_conformed_name",
    "central_index_key_header",
    "primary_document_from_event",
    "acceptance_datetime_from_submissions",
    "timestamp_quality_flag",
    "timestamp_quality_notes",
    "accession_lineage_key",
]


def read_complete_submission_text(path: str | Path, *, max_chars: int | None = None) -> str:
    p = Path(path)
    if p.suffix == ".gz" or p.name.endswith(".txt.gz"):
        with gzip.open(p, "rt", encoding="utf-8", errors="replace") as f:
            text = f.read(max_chars) if max_chars else f.read()
    else:
        with p.open("r", encoding="utf-8", errors="replace") as f:
            text = f.read(max_chars) if max_chars else f.read()
    return text


def extract_sec_header(text: str) -> str:
    """Return SEC header block or conservative beginning slice."""
    end = SEC_HEADER_END_RE.search(text)
    if end:
        return text[: end.end()]
    doc_start = DOCUMENT_START_RE.search(text)
    if doc_start:
        return text[: doc_start.start()]
    return text[:200000]


def parse_header_field(header: str, field: str) -> str:
    pattern = HEADER_FIELD_PATTERNS[field]
    match = pattern.search(header)
    if not match:
        return ""
    return match.group("value").strip()


def parse_acceptance_datetime_raw(header: str) -> str:
    match = ACCEPTANCE_DATETIME_RE.search(header)
    if not match:
        return ""
    return match.group("value").strip()


def parse_acceptance_datetime(raw: str) -> datetime | None:
    if not raw:
        return None
    return datetime.strptime(raw, "%Y%m%d%H%M%S")


def infer_accession_from_filename(path: str | Path) -> str:
    name = Path(path).name
    name = name.replace(".txt.gz", "").replace(".txt", "")
    return name


def infer_cik10_from_path(path: str | Path) -> str:
    parent = Path(path).parent.name
    if parent.isdigit():
        return normalize_cik_10(parent)
    return ""


def find_complete_submission_files(directory: str | Path) -> list[Path]:
    p = Path(directory)
    files = sorted(p.rglob("*.txt")) + sorted(p.rglob("*.txt.gz"))
    return sorted(set(files))


def _yyyymmdd_to_iso(value: str) -> str:
    if not value:
        return ""
    return f"{value[:4]}-{value[4:6]}-{value[6:8]}"


def _load_filing_event_table(path: str | Path | None) -> pd.DataFrame:
    if path is None:
        return pd.DataFrame()
    p = Path(path)
    if not p.exists():
        return pd.DataFrame()
    if p.suffix == ".parquet":
        return pd.read_parquet(p)
    return pd.read_csv(p, dtype=str).fillna("")


def _event_lookup(df: pd.DataFrame) -> dict[tuple[str, str], dict[str, Any]]:
    if df.empty:
        return {}
    required = {"cik10", "accession_number"}
    if not required.issubset(df.columns):
        return {}
    lookup: dict[tuple[str, str], dict[str, Any]] = {}
    for _, row in df.iterrows():
        cik10 = normalize_cik_10(str(row.get("cik10") or row.get("cik") or "0"))
        accession = str(row.get("accession_number") or "").strip()
        if cik10 and accession:
            lookup[(cik10, accession)] = row.to_dict()
    return lookup


def parse_complete_submission_header(
    path: str | Path,
    *,
    event_row: dict[str, Any] | None = None,
    timezone_name: str = DEFAULT_MARKET_TIMEZONE,
    holidays: set | None = None,
    market_close_hour: int = 16,
    market_close_minute: int = 0,
) -> dict[str, Any]:
    p = Path(path)
    text = read_complete_submission_text(p, max_chars=250000)
    header = extract_sec_header(text)

    accession_from_filename = infer_accession_from_filename(p)
    cik10_from_path = infer_cik10_from_path(p)

    raw_acceptance = parse_acceptance_datetime_raw(header)
    accepted_naive = parse_acceptance_datetime(raw_acceptance)

    accession_from_header = parse_header_field(header, "accession_number_header")
    accession = accession_from_header or accession_from_filename
    cik_header = parse_header_field(header, "central_index_key")
    cik10 = normalize_cik_10(cik_header or cik10_from_path or (event_row or {}).get("cik10", "0"))
    cik = normalize_cik_no_leading_zeros(cik10)

    form_header = parse_header_field(header, "submission_type_header")
    filed_header = _yyyymmdd_to_iso(parse_header_field(header, "filed_as_of_date_header"))
    report_header = _yyyymmdd_to_iso(parse_header_field(header, "period_of_report_header"))

    event_row = event_row or {}
    form_event = str(event_row.get("form_type", "") or "")
    filing_event = str(event_row.get("filing_date", "") or "")
    report_event = str(event_row.get("report_date", "") or "")
    primary_doc_event = str(event_row.get("primary_document", "") or "")
    acceptance_from_submissions = str(event_row.get("acceptance_datetime_from_submissions", "") or "")

    quality_notes: list[str] = []
    if not raw_acceptance:
        quality_notes.append("missing_acceptance_datetime")
    if accession_from_header and accession_from_filename and accession_from_header != accession_from_filename:
        quality_notes.append("accession_header_filename_mismatch")
    if cik_header and cik10_from_path and normalize_cik_10(cik_header) != cik10_from_path:
        quality_notes.append("cik_header_path_mismatch")
    if form_header and form_event and form_header.upper() != form_event.upper():
        quality_notes.append("form_header_event_mismatch")
    if filed_header and filing_event and filed_header != filing_event:
        quality_notes.append("filing_date_header_event_mismatch")
    if report_header and report_event and report_header != report_event:
        quality_notes.append("report_date_header_event_mismatch")

    if accepted_naive is None:
        accepted_local_iso = ""
        accepted_date = ""
        accepted_time = ""
        execution_date = ""
    else:
        accepted_local = localize_naive_edgar_datetime(accepted_naive, timezone_name=timezone_name)
        accepted_local_iso = accepted_local.isoformat()
        accepted_date = accepted_local.date().isoformat()
        accepted_time = accepted_local.time().isoformat()
        execution_date = first_allowed_execution_date(
            accepted_naive,
            timezone_name=timezone_name,
            holidays=holidays,
            close_hour=market_close_hour,
            close_minute=market_close_minute,
        ).isoformat()

    if not quality_notes:
        quality_flag = "GREEN"
    elif "missing_acceptance_datetime" in quality_notes:
        quality_flag = "RED"
    elif any("mismatch" in note for note in quality_notes):
        quality_flag = "YELLOW"
    else:
        quality_flag = "YELLOW"

    return {
        "cik": cik,
        "cik10": cik10,
        "accession_number": accession,
        "accession_no_dashes": accession_no_dashes(accession),
        "form_type_from_header": form_header,
        "form_type_from_event": form_event,
        "filing_date_from_header": filed_header,
        "filing_date_from_event": filing_event,
        "report_date_from_header": report_header,
        "report_date_from_event": report_event,
        "accepted_at_edgar_raw": raw_acceptance,
        "accepted_at_edgar": accepted_local_iso,
        "accepted_at_edgar_timezone": timezone_name,
        "accepted_at_edgar_date": accepted_date,
        "accepted_at_edgar_time": accepted_time,
        "first_allowed_execution_date": execution_date,
        "execution_policy": "before_close_T_plus_1_else_T_plus_2_close",
        "header_source_file": str(p),
        "source_file_size_bytes": p.stat().st_size,
        "company_conformed_name": parse_header_field(header, "company_conformed_name"),
        "central_index_key_header": cik_header,
        "primary_document_from_event": primary_doc_event,
        "acceptance_datetime_from_submissions": acceptance_from_submissions,
        "timestamp_quality_flag": quality_flag,
        "timestamp_quality_notes": ";".join(quality_notes),
        "accession_lineage_key": f"{cik10}:{accession}",
    }


def build_filing_availability(config: FilingAvailabilityConfig) -> pd.DataFrame:
    logger = get_logger(
        "fvn_dfm.filing_availability",
        root() / "logs/pipeline/filing_availability.log",
    )
    files = find_complete_submission_files(config.complete_submissions_dir)
    if not files:
        raise FileNotFoundError(f"No complete submission .txt/.txt.gz files found in {config.complete_submissions_dir}")

    event_df = _load_filing_event_table(config.filing_event_path)
    lookup = _event_lookup(event_df)
    holidays = load_holidays(config.holidays_path)

    rows: list[dict[str, Any]] = []
    for file_path in files:
        accession = infer_accession_from_filename(file_path)
        cik10 = infer_cik10_from_path(file_path)
        event_row = lookup.get((cik10, accession), {})
        rows.append(
            parse_complete_submission_header(
                file_path,
                event_row=event_row,
                timezone_name=config.timezone_name,
                holidays=holidays,
                market_close_hour=config.market_close_hour,
                market_close_minute=config.market_close_minute,
            )
        )

    df = pd.DataFrame(rows, columns=FILING_AVAILABILITY_COLUMNS)
    if not df.empty:
        df = df.sort_values(["cik10", "accepted_at_edgar", "accession_number"]).reset_index(drop=True)

    config.output_table_path.parent.mkdir(parents=True, exist_ok=True)
    config.output_csv_path.parent.mkdir(parents=True, exist_ok=True)
    df.to_parquet(config.output_table_path, index=False)
    df.to_csv(config.output_csv_path, index=False)

    logger.info("Wrote %d filing availability rows to %s", len(df), config.output_table_path)
    return df


def main() -> None:
    parser = argparse.ArgumentParser(description="Build filing availability table from complete submissions.")
    parser.add_argument("--complete-submissions-dir", default="data/raw/sec/complete_submissions")
    parser.add_argument("--filing-event-path", default="data/processed/source_tables/sec_filing_event.csv")
    parser.add_argument("--output-table", default="data/processed/point_in_time/filing_availability.parquet")
    parser.add_argument("--output-csv", default="data/processed/point_in_time/filing_availability.csv")
    parser.add_argument("--holidays-path", default="data/raw/calendars/us_market_holidays.csv")
    parser.add_argument("--timezone-name", default=DEFAULT_MARKET_TIMEZONE)
    args = parser.parse_args()

    config = FilingAvailabilityConfig(
        complete_submissions_dir=root() / args.complete_submissions_dir,
        filing_event_path=root() / args.filing_event_path if args.filing_event_path else None,
        output_table_path=root() / args.output_table,
        output_csv_path=root() / args.output_csv,
        holidays_path=root() / args.holidays_path if args.holidays_path else None,
        timezone_name=args.timezone_name,
    )
    build_filing_availability(config)


if __name__ == "__main__":
    main()
