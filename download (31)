@dataclass(frozen=True)
class PublicationPackageConfig:
    package_dir: Path
    package_zip_path: Path
    manifest_output_table_path: Path
    manifest_output_csv_path: Path
    exclusions_output_csv_path: Path
    sanitization_output_csv_path: Path
    diagnostics_path: Path
    include_missing_optional: bool = True
    package_version: str = PUBLICATION_PACKAGE_VERSION


def _utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _sha256_file(path: Path, chunk_size: int = 1024 * 1024) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(chunk_size), b""):
            h.update(chunk)
    return h.hexdigest()


def _read_csv(path: Path) -> pd.DataFrame:
    if not path.exists():
        return pd.DataFrame()
    try:
        return pd.read_csv(path)
    except Exception:
        return pd.DataFrame()


def _is_forbidden_path(relative_path: str) -> tuple[bool, str]:
    normalized = relative_path.replace("\\", "/")
    for prefix in NEVER_INCLUDE_PREFIXES:
        if normalized.startswith(prefix):
            return True, f"forbidden_prefix:{prefix}"
    for suffix in NEVER_INCLUDE_SUFFIXES:
        if normalized.endswith(suffix):
            return True, f"forbidden_suffix:{suffix}"
    return False, ""


def _copy_file(repo_root: Path, package_dir: Path, relative_path: str, section: str) -> dict[str, Any]:
    source = repo_root / relative_path
    forbidden, reason = _is_forbidden_path(relative_path)
    if forbidden:
        return {
            "relative_path": relative_path,
            "package_path": "",
            "section": section,
            "included": False,
            "reason": reason,
            "size_bytes": "",
            "sha256": "",
            "package_version": PUBLICATION_PACKAGE_VERSION,
        }

    if not source.exists() or not source.is_file():
        return {
            "relative_path": relative_path,
            "package_path": "",
            "section": section,
            "included": False,
            "reason": "missing_optional",
            "size_bytes": "",
            "sha256": "",
            "package_version": PUBLICATION_PACKAGE_VERSION,
        }

    dest = package_dir / relative_path
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, dest)
    return {
        "relative_path": relative_path,
        "package_path": dest.relative_to(package_dir).as_posix(),
        "section": section,
        "included": True,
        "reason": "included",
        "size_bytes": int(dest.stat().st_size),
        "sha256": _sha256_file(dest),
        "package_version": PUBLICATION_PACKAGE_VERSION,
    }


def build_publication_manifest(config: PublicationPackageConfig) -> tuple[pd.DataFrame, pd.DataFrame]:
    repo_root = root()
    rows: list[dict[str, Any]] = []

    for rel in PUBLIC_DOCUMENTS:
        rows.append(_copy_file(repo_root, config.package_dir, rel, "public_documents"))
    for rel in PUBLIC_REPORTS:
        rows.append(_copy_file(repo_root, config.package_dir, rel, "public_reports"))
    for rel in PUBLIC_TABLES:
        rows.append(_copy_file(repo_root, config.package_dir, rel, "public_tables"))
    for rel in PUBLIC_REPRO_INDEX:
        rows.append(_copy_file(repo_root, config.package_dir, rel, "reproducibility_index"))

    manifest = pd.DataFrame([r for r in rows if r["included"]])
    exclusions = pd.DataFrame([r for r in rows if not r["included"]])
    return manifest, exclusions


def _scan_text_file(path: Path) -> list[str]:
    issues: list[str] = []
    try:
        text = path.read_text(encoding="utf-8", errors="replace").lower()
    except Exception:
        return issues
    for pattern in SENSITIVE_TEXT_PATTERNS:
        if pattern in text:
            issues.append(f"sensitive_pattern:{pattern}")
    return issues


def build_sanitization_checks(config: PublicationPackageConfig, manifest: pd.DataFrame) -> pd.DataFrame:
    rows: list[dict[str, Any]] = []

    def add(check_id: str, status: str, observed: Any, message: str) -> None:
        rows.append(
            {
                "check_id": check_id,
                "status": status,
                "observed": observed,
                "message": message,
                "checked_at_utc": _utc_now(),
                "package_version": config.package_version,
            }
        )

    included_paths = manifest["package_path"].astype(str).tolist() if not manifest.empty else []
    forbidden_included: list[str] = []
    for path in included_paths:
        forbidden, reason = _is_forbidden_path(path)
        if forbidden:
            forbidden_included.append(f"{path}:{reason}")

    add(
        "NO_FORBIDDEN_PATHS_INCLUDED",
        "PASS" if not forbidden_included else "FAIL",
        ";".join(forbidden_included) if forbidden_included else "none",
        "No forbidden raw/private/log/data paths are included." if not forbidden_included else "Forbidden paths were included.",
    )

    nested_archives = [p for p in included_paths if p.endswith(".zip")]
    add(
        "NO_NESTED_ARCHIVES",
        "PASS" if not nested_archives else "FAIL",
        ";".join(nested_archives) if nested_archives else "none",
        "No nested ZIP archives are included." if not nested_archives else "Nested archives are included.",
    )

    sensitive_hits: list[str] = []
    for package_path in included_paths:
        full = config.package_dir / package_path
        if full.suffix.lower() in {".md", ".txt", ".csv", ".json", ".yaml", ".yml", ".toml"} and full.exists():
            issues = _scan_text_file(full)
            for issue in issues:
                sensitive_hits.append(f"{package_path}:{issue}")

    add(
        "NO_SENSITIVE_TEXT_PATTERNS",
        "PASS" if not sensitive_hits else "FAIL",
        ";".join(sensitive_hits) if sensitive_hits else "none",
        "No configured sensitive text patterns were found." if not sensitive_hits else "Potential sensitive text patterns found.",
    )

    add(
        "PUBLIC_README_PRESENT",
        "PASS" if (config.package_dir / "PUBLICATION_README.md").exists() else "FAIL",
        (config.package_dir / "PUBLICATION_README.md").exists(),
        "Publication README exists.",
    )

    return pd.DataFrame(rows)



def render_publication_readme(manifest: pd.DataFrame, exclusions: pd.DataFrame, config: PublicationPackageConfig) -> str:
    release_summary = _read_csv(root() / "data/processed/reports/release_gate_summary.csv")
    final_verdict = _read_csv(root() / "data/processed/reports/final_research_verdict.csv")
    schema_summary = _read_csv(root() / "data/processed/reports/schema_contract_summary.csv")
    live_readiness = _read_csv(root() / "data/processed/reports/live_data_readiness_summary.csv")
    sanitization_path = config.package_dir / "publication_sanitization_checks.csv"
    sanitization = _read_csv(sanitization_path)

    return render_public_landing_readme(
        manifest=manifest,
        exclusions=exclusions,
        sanitization=sanitization,
        release_summary=release_summary,
        final_verdict=final_verdict,
        schema_summary=schema_summary,
        live_readiness=live_readiness,
        version=PUBLICATION_PACKAGE_VERSION,
    )


def build_publication_diagnostics(manifest: pd.DataFrame, exclusions: pd.DataFrame, sanitization: pd.DataFrame, config: PublicationPackageConfig) -> pd.DataFrame:
    rows: list[dict[str, Any]] = [
        {"diagnostic": "package_version", "value": config.package_version},
        {"diagnostic": "included_files", "value": len(manifest)},
        {"diagnostic": "excluded_or_missing_files", "value": len(exclusions)},
        {"diagnostic": "sanitization_checks", "value": len(sanitization)},
        {"diagnostic": "sanitization_failures", "value": int((sanitization["status"] == "FAIL").sum()) if not sanitization.empty else 1},
        {"diagnostic": "package_dir", "value": config.package_dir.as_posix()},
        {"diagnostic": "package_zip_path", "value": config.package_zip_path.as_posix()},
    ]
    if not manifest.empty:
        rows.append({"diagnostic": "total_size_bytes", "value": int(pd.to_numeric(manifest["size_bytes"], errors="coerce").fillna(0).sum())})
        for section, count in manifest["section"].value_counts().items():
            rows.append({"diagnostic": f"included_{section}", "value": int(count)})
    return pd.DataFrame(rows)


def write_publication_package_outputs(
    manifest: pd.DataFrame,
    exclusions: pd.DataFrame,
    sanitization: pd.DataFrame,
    diagnostics: pd.DataFrame,
    *,
    config: PublicationPackageConfig,
) -> None:
    config.package_dir.mkdir(parents=True, exist_ok=True)

    package_manifest = config.package_dir / "publication_manifest.csv"
    package_exclusions = config.package_dir / "publication_exclusions.csv"
    package_sanitization = config.package_dir / "publication_sanitization_checks.csv"
    package_diagnostics = config.package_dir / "publication_package_diagnostics.csv"
    package_readme = config.package_dir / "PUBLICATION_README.md"

    manifest.to_csv(package_manifest, index=False)
    exclusions.to_csv(package_exclusions, index=False)
    sanitization.to_csv(package_sanitization, index=False)
    diagnostics.to_csv(package_diagnostics, index=False)
    package_readme.write_text(render_publication_readme(manifest, exclusions, config), encoding="utf-8")

    # Re-run sanitization after README/manifest files exist, then overwrite outputs.
    sanitization = build_sanitization_checks(config, manifest)
    diagnostics = build_publication_diagnostics(manifest, exclusions, sanitization, config)
    sanitization.to_csv(package_sanitization, index=False)
    diagnostics.to_csv(package_diagnostics, index=False)
    package_readme.write_text(render_publication_readme(manifest, exclusions, config), encoding="utf-8")

    safe_write_table(manifest, parquet_path=config.manifest_output_table_path, csv_path=config.manifest_output_csv_path)
    config.exclusions_output_csv_path.parent.mkdir(parents=True, exist_ok=True)
    exclusions.to_csv(config.exclusions_output_csv_path, index=False)
    config.sanitization_output_csv_path.parent.mkdir(parents=True, exist_ok=True)
    sanitization.to_csv(config.sanitization_output_csv_path, index=False)
    config.diagnostics_path.parent.mkdir(parents=True, exist_ok=True)
    diagnostics.to_csv(config.diagnostics_path, index=False)

    if config.package_zip_path.exists():
        config.package_zip_path.unlink()
    config.package_zip_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.make_archive(str(config.package_zip_path.with_suffix("")), "zip", config.package_dir)


def build_publication_package(config: PublicationPackageConfig) -> pd.DataFrame:
    logger = get_logger(
        "fvn_dfm.publication_package",
        root() / "logs/pipeline/publication_package.log",
    )
    logger.info("Building publication package at %s", config.package_dir)

    if config.package_dir.exists():
        shutil.rmtree(config.package_dir)
    config.package_dir.mkdir(parents=True, exist_ok=True)

    manifest, exclusions = build_publication_manifest(config)
    # Initial README so sanitization can check it after final write.
    (config.package_dir / "PUBLICATION_README.md").write_text(render_publication_readme(manifest, exclusions, config), encoding="utf-8")
    sanitization = build_sanitization_checks(config, manifest)
    diagnostics = build_publication_diagnostics(manifest, exclusions, sanitization, config)
    write_publication_package_outputs(manifest, exclusions, sanitization, diagnostics, config=config)

    logger.info("Built publication package with %d included files.", len(manifest))
    return manifest


def default_config(repo_root: Path | None = None) -> PublicationPackageConfig:
    r = repo_root or root()
    return PublicationPackageConfig(
        package_dir=r / "outputs/publication/publication_package_v0",
        package_zip_path=r / "outputs/publication/publication_package_v0.zip",
        manifest_output_table_path=r / "data/processed/reports/publication_manifest.parquet",
        manifest_output_csv_path=r / "data/processed/reports/publication_manifest.csv",
        exclusions_output_csv_path=r / "data/processed/reports/publication_exclusions.csv",
        sanitization_output_csv_path=r / "data/processed/reports/publication_sanitization_checks.csv",
        diagnostics_path=r / "outputs/diagnostics/publication_package_diagnostics.csv",
    )


def main() -> None:
    parser = argparse.ArgumentParser(description="Build sanitized publication package v0.")
    parser.add_argument("--package-dir", default="outputs/publication/publication_package_v0")
    parser.add_argument("--package-zip-path", default="outputs/publication/publication_package_v0.zip")
    parser.add_argument("--manifest-output-table", default="data/processed/reports/publication_manifest.parquet")
    parser.add_argument("--manifest-output-csv", default="data/processed/reports/publication_manifest.csv")
    parser.add_argument("--exclusions-output-csv", default="data/processed/reports/publication_exclusions.csv")
    parser.add_argument("--sanitization-output-csv", default="data/processed/reports/publication_sanitization_checks.csv")
    parser.add_argument("--diagnostics-path", default="outputs/diagnostics/publication_package_diagnostics.csv")
    args = parser.parse_args()

    r = root()
    config = PublicationPackageConfig(
        package_dir=r / args.package_dir,
        package_zip_path=r / args.package_zip_path,
        manifest_output_table_path=r / args.manifest_output_table,
        manifest_output_csv_path=r / args.manifest_output_csv,
        exclusions_output_csv_path=r / args.exclusions_output_csv,
        sanitization_output_csv_path=r / args.sanitization_output_csv,
        diagnostics_path=r / args.diagnostics_path,
    )
    build_publication_package(config)


if __name__ == "__main__":
    main()
